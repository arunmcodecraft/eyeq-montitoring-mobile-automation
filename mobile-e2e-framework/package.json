{
  "name": "mobile-e2e-framework",
  "version": "1.0.0",
  "description": "WebdriverIO JavaScript mobile automation framework for Android and iOS using Cucumber.",
  "main": "index.js",
  "scripts": {
    "test:android": "wdio run ./config/wdio.android.conf.js",
    "test:ios": "wdio run ./config/wdio.ios.conf.js",
    "test:android:smoke": "wdio run ./config/wdio.android.conf.js --cucumberOpts.tagExpression=@smoke",
    "report:allure": "allure generate reports/allure-results --clean -o reports/html-report",
    "encrypt:credential": "node -e \"const cryptoUtil=require('./src/utils/encryption/crypto.util'); console.log(cryptoUtil.encryptValue(process.argv[1] || 'sample'));\""
  },
  "keywords": [
    "webdriverio",
    "appium",
    "cucumber",
    "mobile-automation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.1",
    "@wdio/allure-reporter": "^9.18.0",
    "@wdio/appium-service": "^9.18.0",
    "@wdio/cli": "^9.18.0",
    "@wdio/cucumber-framework": "^9.18.0",
    "@wdio/local-runner": "^9.18.0",
    "@wdio/spec-reporter": "^9.18.0",
    "allure-commandline": "^2.32.0",
    "appium": "^2.17.1",
    "appium-uiautomator2-driver": "^3.7.9"
  }
}
